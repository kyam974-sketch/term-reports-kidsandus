<script>
// ═══════════════════════════════════════════════════
// AUTH - Simple credential check (customize here)
// ═══════════════════════════════════════════════════
const CREDENTIALS = {
  "chiara.marchese@kidsandus.it": "KidsUs2025!",
  "admin": "admin123"
};

let currentUser = null;

function handleLogin() {
  const email = document.getElementById('login-email').value.trim();
  const pass = document.getElementById('login-pass').value;
  
  if (CREDENTIALS[email] === pass) {
    currentUser = email;
    document.getElementById('login-screen').style.display = 'none';
    document.getElementById('app').style.display = 'block';
    document.getElementById('user-name-display').textContent = email.split('.')[0].charAt(0).toUpperCase() + email.split('.')[0].slice(1);
    renderHistory();
  } else {
    document.getElementById('login-error').style.display = 'block';
    setTimeout(() => document.getElementById('login-error').style.display = 'none', 3000);
  }
}

function handleLogout() {
  currentUser = null;
  document.getElementById('app').style.display = 'none';
  document.getElementById('login-screen').style.display = 'flex';
  document.getElementById('login-email').value = '';
  document.getElementById('login-pass').value = '';
}

// Enter key on login
document.getElementById('login-pass').addEventListener('keydown', e => {
  if (e.key === 'Enter') handleLogin();
});

// ═══════════════════════════════════════════════════
// NAVIGATION
// ═══════════════════════════════════════════════════
function showView(viewId, btn) {
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('view-' + viewId).classList.add('active');
  btn.classList.add('active');
  if (viewId === 'history') renderHistory();
}

// ═══════════════════════════════════════════════════
// COURSE INFO
// ═══════════════════════════════════════════════════
const COURSE_INFO = {
  mousy: {
    label: "Mousy — Babies (0–2 anni)",
    desc: "Familiarizzazione con l'inglese. Comprensione semplici istruzioni. Prime parole: Hello, Bye-bye, Please, Thank you. I genitori partecipano alla lezione. Focus su: suoni, canzoni, routine, parti del corpo, colori, animali."
  },
  linda: {
    label: "Linda — Babies/Toddlers (1,5–3 anni)",
    desc: "Inizia a mettere insieme 2–3 parole. Espressioni quotidiane: saluti, presentazioni, ringraziamenti. Vocabolario: corpo, azioni, colori, dimensioni. I genitori sono presenti. Il bambino inizia a riprodurre strutture."
  },
  sam: {
    label: "Sam — Kids (2,5–4 anni)",
    desc: "Comprensione globale delle storie. Saluti, presentazione (nome, età), stati d'animo. Descrizione oggetti (colore, dimensione). 'Can I have... please?'. Vocabolario: routine, azioni, animali, alimenti."
  },
  emma: {
    label: "Emma — Kids (3–5 anni)",
    desc: "Comunicazione con strutture brevi: 'It's rainy', 'Emma can eat in the kitchen'. Comprensione delle storie. Presentazione completa (nome, età, stato d'animo). Preferenze: 'I like strawberries'. Storie della personaggioEmma."
  },
  oliver: {
    label: "Oliver — Kids (4–6 anni)",
    desc: "Produzione di frasi più articolate. Strutture per chiedere/rispondere. Comprensione estesa. Vocabolario più ricco. Lavoro sul workbook con maggiore autonomia."
  },
  marcia: {
    label: "Marcia — Junior (5–7 anni)",
    desc: "Strutture comunicative più complesse. Lettura/scrittura iniziale. Autonomia nelle attività. Comprensione di istruzioni elaborate. Maggiore produzione orale."
  },
  pam_paul: {
    label: "Pam & Paul — Junior (6–8 anni)",
    desc: "Corso avanzato. Lettura, scrittura, grammatica di base. Conversazione strutturata. Uso del workbook autonomo."
  },
  ben_brenda: {
    label: "Ben & Brenda — Pre-teens (8–11 anni)",
    desc: "Livello intermedio. Abilità integrate (lettura, scrittura, ascolto, parlato). Grammatica, vocabolario tematico, comprensione testi."
  }
};

function onCourseChange() {
  const course = document.getElementById('course-select').value;
  const panel = document.getElementById('course-info-panel');
  if (course && COURSE_INFO[course]) {
    const info = COURSE_INFO[course];
    panel.innerHTML = `<strong>${info.label}</strong><br>${info.desc}`;
    panel.classList.add('visible');
  } else {
    panel.classList.remove('visible');
  }
}

// ═══════════════════════════════════════════════════
// REPORT TYPE
// ═══════════════════════════════════════════════════
let reportType = 'trimestrale';

function setReportType(type) {
  reportType = type;
  document.getElementById('btn-trimestrale').classList.toggle('active', type === 'trimestrale');
  document.getElementById('btn-finale').classList.toggle('active', type === 'finale');
}

// ═══════════════════════════════════════════════════
// FILE UPLOAD
// ═══════════════════════════════════════════════════
let uploadedFileContent = '';

function handleFileUpload(input) {
  const file = input.files[0];
  if (!file) return;
  
  document.getElementById('uploaded-file-name').textContent = file.name;
  document.getElementById('uploaded-file-info').style.display = 'flex';
  
  const reader = new FileReader();
  reader.onload = (e) => { uploadedFileContent = e.target.result; };
  reader.readAsText(file);
}

function clearUpload() {
  uploadedFileContent = '';
  document.getElementById('uploaded-file-info').style.display = 'none';
  document.getElementById('prev-report-file').value = '';
}

// ═══════════════════════════════════════════════════
// GENERATE REPORT
// ═══════════════════════════════════════════════════
let currentReport = null;

const LOADING_MESSAGES = [
  "Analisi dei follow-up in corso...",
  "Personalizzazione del tono sul tipo di genitore...",
  "Stesura delle sezioni del report...",
  "Revisione della qualità linguistica..."
];

async function generateReport() {
  const studentName = document.getElementById('student-name').value.trim();
  const course = document.getElementById('course-select').value;
  const trimestre = document.getElementById('trimestre-select').value;
  const gender = document.getElementById('gender-select').value;
  const oralTest = document.getElementById('oral-test').value.trim();
  const followups = document.getElementById('followups').value.trim();
  const extraNotes = document.getElementById('extra-notes').value.trim();
  const parentType = document.querySelector('input[name="parent-type"]:checked').value;
  const prevReport = uploadedFileContent || document.getElementById('prev-report-text').value.trim();

  if (!studentName || !course || !followups) {
    alert('Compila almeno: nome studente, corso e follow-up delle lezioni.');
    return;
  }

  const btn = document.getElementById('generate-btn');
  btn.disabled = true;
  document.getElementById('loading-bar').classList.add('active');
  document.getElementById('results-area').style.display = 'none';

  let msgIdx = 0;
  const msgInterval = setInterval(() => {
    document.getElementById('loading-msg').textContent = LOADING_MESSAGES[msgIdx % LOADING_MESSAGES.length];
    msgIdx++;
  }, 2500);

  try {
    const courseInfo = COURSE_INFO[course];
    const pronome = gender === 'M' ? 'lui/il bambino' : 'lei/la bambina';
    const pronome2 = gender === 'M' ? 'Lo' : 'La';
    const articolo = gender === 'M' ? 'il' : 'la';
    const finaleInstructions = reportType === 'finale' ? `
- SEZIONE AGGIUNTIVA "Valutazione generale anno scolastico": Fornisci un giudizio complessivo sull'anno, evidenziando i progressi fatti dal primo al terzo trimestre, il livello raggiunto, e dai consigli pratici per l'estate (es. ascolto audio, routine, attività per mantenere/migliorare quanto appreso) in vista dell'anno successivo.` : '';

    const parentGuidance = {
      standard: "Tono professionale, caldo e rassicurante. Bilancia aspetti positivi e aree di miglioramento in modo diretto.",
      permaloso: "Tono molto diplomatico e rassicurante. Qualsiasi aspetto critico va incorniciato come opportunità di crescita, mai come problema. Sottolinea moltissimo i progressi. Evita qualsiasi formulazione che possa essere percepita come critica.",
      pignolo: "Tono preciso, dettagliato e professionale. Il genitore vuole informazioni concrete e specifiche. Usa esempi precisi. Spiega le strategie didattiche. Sii puntuale e metodico.",
      ansioso: "Tono molto rassicurante e positivo. Ogni possibile preoccupazione deve essere subito bilanciata da una rassicurazione. Sottolinea che tutto è sotto controllo e che le strategie sono già in atto.",
      entusiasta: "Tono caldo ed energico. Il genitore è già motivato, quindi puoi essere più diretto nel condividere anche le sfide, sapendo che le accoglierà positivamente.",
      distaccato: "Tono formale e molto professionale. Fatti concreti, progressi misurabili, strategie chiare. Meno calore, più sostanza e precisione."
    };

    const systemPrompt = `Sei un'esperta insegnante di inglese di Kids&Us con anni di esperienza nella redazione di term report per bambini. 
Scrivi SEMPRE in italiano perfetto e naturale, come farebbe una madrelingua italiana colta. 
EVITA assolutamente traduzioni letterali dall'inglese o frasi innaturali in italiano.
Usa un registro professionale ma accessibile ai genitori.
Il report è scritto in terza persona (es. "Aurora partecipa attivamente...") oppure con "noi" del plurale scolastico.
NON usare la prima persona singolare della insegnante.
NON menzionare mai il tipo di genitore nel testo.
NON fare riferimento alle note interne nel testo del report.
Ogni sezione deve essere di 3-5 righe ben scritte, personalizzate e specifiche per questo studente.
Rispondi SOLO con JSON valido, nessun testo prima o dopo.`;

    const userPrompt = `Genera un term report Kids&Us per il seguente studente:

DATI STUDENTE:
- Nome: ${studentName}
- Corso: ${courseInfo.label}
- Trimestre: ${trimestre}
- Genere: ${gender === 'M' ? 'Maschio' : 'Femmina'}
- Anno scolastico: 2024/2025

OBIETTIVI DEL CORSO:
${courseInfo.desc}

FOLLOW-UP LEZIONI:
${followups}

ORAL TEST: ${oralTest || 'Non specificato'}

NOTE INTERNE (NON citarle nel report, usale solo per guidare il tono e i contenuti):
- Tipo di genitore: ${parentType} → ${parentGuidance[parentType]}
- Note integrative: ${extraNotes || 'Nessuna nota aggiuntiva'}

${prevReport ? `REPORT PRECEDENTE (mantieni continuità ed evidenzia eventuali progressi/cambiamenti rispetto a questo):
${prevReport.substring(0, 2000)}` : ''}

Genera il report con le seguenti sezioni. Ogni sezione deve essere testo fluido e naturale in italiano, NON bullet points:

Rispondi con questo JSON esatto:
{
  "motivazione_partecipazione": "testo della sezione...",
  "apprendimento": "testo della sezione...",
  "comportamento": "testo della sezione...",
  "oral_test": "testo commento oral test..."${reportType === 'finale' ? ',\n  "valutazione_annuale": "testo valutazione generale con consigli estate..."' : ''}
}`;

    const response = await fetch("/api/generate", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        model: "claude-sonnet-4-20250514",
        max_tokens: 1800,
        messages: [
          { role: "user", content: userPrompt }
        ],
        system: systemPrompt
      })
    });

    const data = await response.json();
    
    if (!response.ok || !data.content) {
      throw new Error(data.error?.message || 'Errore API');
    }

    const rawText = data.content.find(b => b.type === 'text')?.text || '';
    const jsonMatch = rawText.match(/\{[\s\S]*\}/);
    if (!jsonMatch) throw new Error('Formato risposta non valido');
    
    const sections = JSON.parse(jsonMatch[0]);

    currentReport = {
      id: Date.now().toString(),
      studentName,
      course,
      trimestre,
      gender,
      parentType,
      oralTest,
      reportType,
      date: new Date().toLocaleDateString('it-IT'),
      sections
    };

    renderResults(sections);

  } catch (err) {
    alert('Errore durante la generazione: ' + err.message);
    console.error(err);
  } finally {
    clearInterval(msgInterval);
    btn.disabled = false;
    document.getElementById('loading-bar').classList.remove('active');
  }
}

// ═══════════════════════════════════════════════════
// RENDER RESULTS
// ═══════════════════════════════════════════════════
const SECTION_LABELS = {
  motivazione_partecipazione: "Motivazione e partecipazione",
  apprendimento: "Apprendimento",
  comportamento: "Comportamento",
  oral_test: "Oral test",
  valutazione_annuale: "Valutazione generale anno scolastico"
};

function renderResults(sections) {
  const area = document.getElementById('results-area');
  const alertContainer = document.getElementById('alert-container');
  const container = document.getElementById('sections-container');

  alertContainer.innerHTML = `
    <div class="alert-banner info">
      <span>✦</span>
      <span>Report generato con successo. Clicca <strong>"Copia"</strong> su ogni sezione per incollarla sulla piattaforma Kids&Us.</span>
    </div>`;

  container.innerHTML = '';

  for (const [key, text] of Object.entries(sections)) {
    const label = SECTION_LABELS[key] || key;
    const card = document.createElement('div');
    card.className = 'report-section-card';
    card.innerHTML = `
      <div class="report-section-header">
        <span class="section-label">${label}</span>
        <button class="btn-copy" onclick="copySection(this, '${key}')">
          <span>⎘</span> Copia
        </button>
      </div>
      <div class="report-section-body">
        <div class="report-text" id="text-${key}">${escapeHtml(text)}</div>
      </div>`;
    container.appendChild(card);
  }

  area.style.display = 'block';
  area.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function copySection(btn, key) {
  const text = document.getElementById('text-' + key).textContent;
  navigator.clipboard.writeText(text).then(() => {
    btn.classList.add('copied');
    btn.innerHTML = '<span>✓</span> Copiato!';
    setTimeout(() => {
      btn.classList.remove('copied');
      btn.innerHTML = '<span>⎘</span> Copia';
    }, 2000);
  });
}

function escapeHtml(str) {
  return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

// ═══════════════════════════════════════════════════
// HISTORY (localStorage)
// ═══════════════════════════════════════════════════
function getHistory() {
  try {
    const data = sessionStorage.getItem('tr_history');
    return data ? JSON.parse(data) : [];
  } catch { return []; }
}

function saveHistory(items) {
  sessionStorage.setItem('tr_history', JSON.stringify(items));
}

function saveToHistory() {
  if (!currentReport) return;
  const history = getHistory();
  history.unshift(currentReport);
  saveHistory(history);
  
  const btn = document.querySelector('.btn-save');
  const orig = btn.innerHTML;
  btn.innerHTML = '<span>✓</span> Salvato!';
  btn.style.background = 'var(--success)';
  setTimeout(() => {
    btn.innerHTML = orig;
    btn.style.background = 'var(--sage)';
  }, 2000);
}

function renderHistory() {
  const list = document.getElementById('history-list');
  let items = getHistory();

  const filterCourse = document.getElementById('filter-course').value;
  const filterTerm = document.getElementById('filter-term').value;
  const filterName = document.getElementById('filter-name').value.toLowerCase();

  if (filterCourse) items = items.filter(i => i.course === filterCourse);
  if (filterTerm) items = items.filter(i => i.trimestre === filterTerm);
  if (filterName) items = items.filter(i => i.studentName.toLowerCase().includes(filterName));

  if (items.length === 0) {
    list.innerHTML = `
      <div class="empty-state">
        <div class="empty-icon">◈</div>
        <div class="empty-title">Nessun report salvato</div>
        <div class="empty-desc">Genera un report e salvalo per trovarlo qui.</div>
      </div>`;
    return;
  }

  list.innerHTML = items.map((item, idx) => `
    <div class="history-item">
      <div class="history-item-info">
        <div class="history-student">${item.studentName}</div>
        <div class="history-meta">
          <span><span class="badge badge-course">${COURSE_INFO[item.course]?.label.split('—')[0].trim() || item.course}</span></span>
          <span><span class="badge badge-term">${item.trimestre}</span></span>
          ${item.reportType === 'finale' ? '<span><span class="badge badge-final">Report finale</span></span>' : ''}
          <span>📅 ${item.date}</span>
        </div>
      </div>
      <div class="history-actions">
        <button class="btn-sm" onclick="viewHistoryItem(${idx})">Visualizza</button>
        <button class="btn-sm danger" onclick="deleteHistoryItem(${idx})">Elimina</button>
      </div>
    </div>`).join('');
}

function viewHistoryItem(idx) {
  const items = getHistory();
  const item = items[idx];
  if (!item) return;
  
  document.getElementById('modal-student-name').textContent = item.studentName;
  document.getElementById('modal-meta').textContent = 
    `${COURSE_INFO[item.course]?.label || item.course} · ${item.trimestre} · ${item.date}`;

  const container = document.getElementById('modal-sections-container');
  container.innerHTML = '';

  for (const [key, text] of Object.entries(item.sections)) {
    const label = SECTION_LABELS[key] || key;
    const div = document.createElement('div');
    div.className = 'report-section-card';
    div.style.marginBottom = '14px';
    div.innerHTML = `
      <div class="report-section-header">
        <span class="section-label">${label}</span>
        <button class="btn-copy" onclick="copyText(this, \`${text.replace(/`/g, '\\`')}\`)">
          <span>⎘</span> Copia
        </button>
      </div>
      <div class="report-section-body">
        <div class="report-text">${escapeHtml(text)}</div>
      </div>`;
    container.appendChild(div);
  }

  document.getElementById('modal-view').classList.add('active');
}

function copyText(btn, text) {
  navigator.clipboard.writeText(text).then(() => {
    btn.classList.add('copied');
    btn.innerHTML = '<span>✓</span> Copiato!';
    setTimeout(() => {
      btn.classList.remove('copied');
      btn.innerHTML = '<span>⎘</span> Copia';
    }, 2000);
  });
}

function deleteHistoryItem(idx) {
  if (!confirm('Eliminare questo report dallo storico?')) return;
  const items = getHistory();
  items.splice(idx, 1);
  saveHistory(items);
  renderHistory();
}

function closeModal(id) {
  document.getElementById(id).classList.remove('active');
}
</script>

